// RUN: hlo_to_xtileir %s | FileCheck %s
// RUN: triton_test_correctness %s --abs_error_bound=1e-3 --rel_error_bound=1e-3

// RUN: hlo_to_xtileir %s --use_experimental_tiling | FileCheck %s
// RUN: triton_test_correctness %s --xla_gpu_experimental_enable_tiling_propagation --abs_error_bound=1e-3 --rel_error_bound=1e-3

triton_dot {
  lhs = f8e4m3fn[128,128]{1,0} parameter(0)
  rhs = f8e4m3fn[128,256]{1,0} parameter(1)
  lhs_scale = f8e8m0fnu[128,4]{1,0} parameter(2)
  rhs_scale = f8e8m0fnu[4,256]{1,0} parameter(3)
  ROOT scaled_dot = bf16[128,256]{1,0} scaled-dot(lhs, rhs, lhs_scale, rhs_scale),
    lhs_contracting_dims={1},
    rhs_contracting_dims={0},
    backend_config={sizes:[128]}
}

// CHECK-LABEL:   xtile.entry_func @triton_fn(
// CHECK-SAME:      %[[ARG0:.*]]: memref<128x128xf8E4M3FN>,
// CHECK-SAME:      %[[ARG1:.*]]: memref<128x256xf8E4M3FN>,
// CHECK-SAME:      %[[ARG2:.*]]: memref<128x4xi8>,
// CHECK-SAME:      %[[ARG3:.*]]: memref<4x256xi8>,
// CHECK-SAME:      %[[ARG4:.*]]: memref<128x256xbf16>,
// CHECK-SAME:      %[[ARG5:.*]]: index) attributes {num_opaque_args = 0 : i32} {
// CHECK:           %[[CONSTANT_0:.*]] = arith.constant dense<0.000000e+00> : tensor<128x256xf32>
// CHECK:           %[[CONSTANT_1:.*]] = arith.constant 0 : index
// CHECK:           %[[EXTRACT_0:.*]] = xtile.extract %[[ARG0]][%[[CONSTANT_1]], %[[CONSTANT_1]]] [128, 128] [1, 1] : memref<128x128xf8E4M3FN> -> tensor<128x128xf8E4M3FN>
// CHECK:           %[[EXTRACT_1:.*]] = xtile.extract %[[ARG1]][%[[CONSTANT_1]], %[[CONSTANT_1]]] [128, 256] [1, 1] : memref<128x256xf8E4M3FN> -> tensor<128x256xf8E4M3FN>
// CHECK:           %[[EXTRACT_2:.*]] = xtile.extract %[[ARG2]][%[[CONSTANT_1]], %[[CONSTANT_1]]] [128, 4] [1, 1] : memref<128x4xi8> -> tensor<128x4xi8>
// CHECK:           %[[EXTRACT_3:.*]] = xtile.extract %[[ARG3]][%[[CONSTANT_1]], %[[CONSTANT_1]]] [4, 256] [1, 1] : memref<4x256xi8> -> tensor<4x256xi8>
// CHECK:           %[[TRANS_0:.*]] = tt.trans %[[EXTRACT_3]] {order = array<i32: 1, 0>} : tensor<4x256xi8> -> tensor<256x4xi8>
// CHECK:           %[[DOT_SCALED_0:.*]] = tt.dot_scaled %[[EXTRACT_0]] scale %[[EXTRACT_2]], %[[EXTRACT_1]] scale %[[TRANS_0]], %[[CONSTANT_0]] lhs = e4m3 rhs = e4m3 {fastMath = true} : tensor<128x128xf8E4M3FN>, tensor<128x4xi8> * tensor<128x256xf8E4M3FN>, tensor<256x4xi8> -> tensor<128x256xf32>
// CHECK:           %[[TRUNCF_0:.*]] = arith.truncf %[[DOT_SCALED_0]] : tensor<128x256xf32> to tensor<128x256xbf16>
// CHECK:           xtile.insert %[[TRUNCF_0]] into %[[ARG4]][%[[CONSTANT_1]], %[[CONSTANT_1]]] [128, 256] [1, 1] : tensor<128x256xbf16> -> memref<128x256xbf16>
// CHECK:           xtile.return
// CHECK:         }

ENTRY main {
  lhs = f8e4m3fn[128,128]{1,0} parameter(0)
  rhs = f8e4m3fn[128,256]{1,0} parameter(1)
  lhs_scale = f8e8m0fnu[128,4]{1,0} parameter(2)
  rhs_scale = f8e8m0fnu[4,256]{1,0} parameter(3)
  ROOT fusion = bf16[128,256]{1,0} fusion(lhs, rhs, lhs_scale, rhs_scale),
    kind=kCustom, calls=triton_dot, backend_config={
      "fusion_backend_config": {
        "kind": "__triton_nested_gemm_fusion",
        "block_level_fusion_config":{
          "output_tiles":[{"sizes":["128", "256"]}],
          "num_warps":"4",
          "num_stages":"1",
          "num_ctas":"1"
        }
      }
    }
}
